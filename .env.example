APP_NAME="SST Manager"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_URL=https://seudominio.com.br
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

# ─── BANCO DE DADOS ───────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sst_db
DB_USERNAME=sst_app           # NUNCA use postgres/root em produção
DB_PASSWORD=SENHA_FORTE_AQUI

# ─── CACHE / SESSION ──────────────────────────────────────────────
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true          # Encripta cookies de sessão

# ─── LOGS ─────────────────────────────────────────────────────────
LOG_CHANNEL=daily
LOG_LEVEL=warning             # Em produção: warning ou error

# ─── EMAIL ────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu@email.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@seudominio.com.br
MAIL_FROM_NAME="SST Manager"

# ─── FILESYSTEM ───────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── SEGURANÇA ────────────────────────────────────────────────────
BCRYPT_ROUNDS=12              # Mínimo 12 em produção
MAX_LOGIN_ATTEMPTS=5          # Máximo tentativas de login
LOGIN_THROTTLE_MINUTES=15     # Minutos de bloqueio após tentativas

# ─── RATE LIMITING ────────────────────────────────────────────────
RATE_LIMIT_API=60             # Req/min por IP na API
RATE_LIMIT_LOGIN=5            # Tentativas de login por minuto

# ─── SISTEMA SST ──────────────────────────────────────────────────
SST_SYSTEM_NAME="SST Manager"
SST_SYSTEM_LOGO=
SST_VERSION=2.0.0
SST_MULTIEMPRESA=true
